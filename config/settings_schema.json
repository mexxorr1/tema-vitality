[
  {
    "name": "theme_info",
    "theme_name": "Vitality",
    "theme_author": "Antigravity",
    "theme_version": "2.0.0",
    "theme_documentation_url": "https://github.com/mexxorr1/tema-vitality",
    "theme_support_url": "https://github.com/mexxorr1/tema-vitality/issues"
  },
  {
    "name": "Colores y Tipografía",
    "settings": [
      {
        "type": "header",
        "content": "Colores principales"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Color primario",
        "default": "#000000",
        "info": "Usada en botones, enlaces y elementos destacados"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Color secundario",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Color de acento / Promoción",
        "default": "#FF3300",
        "info": "Usada en badges de promoción y alertas"
      },
      {
        "type": "header",
        "content": "Texto y Fondo"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Color del texto principal",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Color de fondo principal",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_background_secondary",
        "label": "Color de fondo secundario",
        "default": "#F5F5F5",
        "info": "Usada en secciones alternadas y cards"
      },
      {
        "type": "header",
        "content": "Tipografía"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Fuente de los títulos",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Fuente del cuerpo",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "font_size_scale",
        "label": "Escala de tipografía",
        "min": 85,
        "max": 130,
        "step": 5,
        "unit": "%",
        "default": 100,
        "info": "Ajusta el tamaño base de las fuentes en todo el sitio"
      }
    ]
  },
  {
    "name": "Layout y Espaciado",
    "settings": [
      {
        "type": "select",
        "id": "layout_style",
        "label": "Estilo del layout",
        "options": [
          { "value": "wide", "label": "Ancho completo" },
          { "value": "boxed", "label": "Contenido centrado" }
        ],
        "default": "wide"
      },
      {
        "type": "range",
        "id": "section_spacing",
        "label": "Espaciado entre secciones",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "default": 36
      },
      {
        "type": "range",
        "id": "border_radius",
        "label": "Redondeo de bordes",
        "min": 0,
        "max": 40,
        "step": 4,
        "unit": "px",
        "default": 16,
        "info": "Afecta botones, cards y contenedores"
      }
    ]
  },
  {
    "name": "Redes Sociales",
    "settings": [
      {
        "type": "header",
        "content": "Cuentas de redes sociales"
      },
      {
        "type": "url",
        "id": "social_instagram_link",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_tiktok_link",
        "label": "TikTok"
      },
      {
        "type": "url",
        "id": "social_facebook_link",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_youtube_link",
        "label": "YouTube"
      },
      {
        "type": "url",
        "id": "social_twitter_link",
        "label": "X (Twitter)"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Imagen del favicon",
        "info": "Se recomienda 32x32 px en formato PNG"
      }
    ]
  },
  {
    "name": "Barra de Promoción",
    "settings": [
      {
        "type": "checkbox",
        "id": "promo_bar_enabled",
        "label": "Mostrar barra de promoción",
        "default": true
      },
      {
        "type": "text",
        "id": "promo_bar_text",
        "label": "Texto de la promoción",
        "default": "🔥 Envío GRATIS en pedidos +$69 | Oferta por tiempo limitado"
      },
      {
        "type": "color",
        "id": "promo_bar_bg",
        "label": "Color de fondo",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "promo_bar_text_color",
        "label": "Color del texto",
        "default": "#ffffff"
      }
    ]
  },
  {
    "name": "Carrito",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Tipo de carrito",
        "options": [
          { "value": "drawer", "label": "Panel lateral (Drawer)" },
          { "value": "page", "label": "Página completa" }
        ],
        "default": "drawer"
      },
      {
        "type": "product",
        "id": "sticky_cart_product",
        "label": "Producto para el sticky add-to-cart (móvil)"
      }
    ]
  }
]
