<section class="w-full mx-auto mb-20 px-6 md:px-12 xl:px-24 overflow-hidden relative" data-carousel>
  <div class="text-center mb-14">
    <h2 class="text-4xl md:text-[3.5rem] font-medium tracking-tight text-foreground leading-[1.1]">
      {{ section.settings.heading | replace: 'Nossos Clientes', '<span class="text-primary italic">Nossos Clientes</span>' }}
    </h2>
  </div>

  <div class="relative max-w-[1400px] mx-auto group/carousel">
    
    <button id="car-prev-{{ section.id }}" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 md:-translate-x-6 z-10 w-14 h-14 bg-background/90 backdrop-blur-md rounded-full border border-border shadow-lg flex items-center justify-center text-foreground hover:bg-primary hover:text-primary-foreground hover:border-primary transition-all opacity-0 invisible group-hover/carousel:opacity-100 group-hover/carousel:visible focus:outline-none">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
    </button>

    <button id="car-next-{{ section.id }}" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 md:translate-x-6 z-10 w-14 h-14 bg-background/90 backdrop-blur-md rounded-full border border-border shadow-lg flex items-center justify-center text-foreground hover:bg-primary hover:text-primary-foreground hover:border-primary transition-all opacity-0 invisible group-hover/carousel:opacity-100 group-hover/carousel:visible focus:outline-none">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
    </button>

    <div id="car-track-{{ section.id }}" class="flex gap-6 overflow-x-auto snap-x snap-mandatory px-4 py-8 hide-scrollbar scroll-smooth" style="scrollbar-width: none; -ms-overflow-style: none;">
      {%- for block in section.blocks -%}
        <div class="snap-center shrink-0 w-[85vw] sm:w-[50vw] md:w-[400px] lg:w-[420px] bg-card border border-border/80 rounded-[2.5rem] p-8 lg:p-10 shadow-sm hover:shadow-2xl hover:shadow-primary/10 transition-all duration-500 ease-out transform hover:-translate-y-2 flex flex-col justify-between group" {{ block.shopify_attributes }}>
          <div>
            <div class="flex gap-1 mb-6 text-primary group-hover:scale-105 transform origin-left transition-transform duration-300">
              {%- for i in (1..5) -%}
                {%- if i <= block.settings.rating -%}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {%- else -%}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="opacity-40"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
            <p class="text-foreground text-[1.1rem] leading-relaxed mb-8 font-sans">
              "{{ block.settings.review_text | escape }}"
            </p>
          </div>
          <div class="border-t border-border/50 pt-6 mt-auto">
            <h4 class="font-semibold text-foreground text-lg tracking-tight mb-1">{{ block.settings.author }}</h4>
            <span class="text-muted-foreground text-sm font-medium">{{ block.settings.product_mentioned }}</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const track = document.getElementById('car-track-{{ section.id }}');
  const prevBtn = document.getElementById('car-prev-{{ section.id }}');
  const nextBtn = document.getElementById('car-next-{{ section.id }}');
  
  if (track && prevBtn && nextBtn) {
    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -420, behavior: 'smooth' });
    });
    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: 420, behavior: 'smooth' });
    });
  }
});
</script>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Resultados Reais dos Nossos Clientes"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "Review maravilhoso sobre o produto."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Nome C."
        },
        {
          "type": "text",
          "id": "product_mentioned",
          "label": "Product string",
          "default": "Corretor de Postura"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Carousel",
      "blocks": [
        {"type": "review"},
        {"type": "review"},
        {"type": "review"}
      ]
    }
  ]
}
{% endschema %}
