<section class="relative w-full min-h-screen flex items-center overflow-hidden">
  <!-- Background Video / Image -->
  {%- if section.settings.video_url != blank -%}
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover">
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {%- elsif section.settings.background_image != blank -%}
    <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager">
  {%- else -%}
    <div class="absolute inset-0 bg-gradient-to-br from-background via-muted/30 to-background"></div>
  {%- endif -%}
  <div class="absolute inset-0 bg-gradient-to-t from-background via-background/60 to-transparent"></div>

  <div class="relative z-10 w-full mx-auto px-6 md:px-12 xl:px-24 py-40">
    <div class="max-w-3xl">
      {%- if section.settings.social_proof_text != blank -%}
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-foreground/[0.07] border border-border/30 text-sm text-muted-foreground font-sans mb-6 animate-fade-in backdrop-blur-sm">
          <span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          {{ section.settings.social_proof_text }}
        </div>
      {%- endif -%}

      <h1 class="text-[clamp(2.5rem,7vw,5rem)] font-medium italic tracking-tight leading-[1.05] text-foreground mb-8">
        {{ section.settings.heading }}
      </h1>
      
      {%- if section.settings.subheading != blank -%}
        <div class="text-lg md:text-xl text-muted-foreground font-sans leading-relaxed max-w-xl mb-10">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_link | default: routes.root_url }}" class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-primary text-primary-foreground font-semibold text-lg hover:brightness-110 hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-primary/30">
          {{ section.settings.button_text }}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.delivery_text != blank -%}
        <p class="mt-6 text-sm text-muted-foreground/70 font-sans flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          {{ section.settings.delivery_text }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "social_proof_text",
      "label": "Texto de prueba social",
      "default": "+15,400 espaldas aliviadas"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Título principal",
      "default": "Despierta sin dolor.\nCorrige tu postura."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "<p>El corrector inteligente que entrena tu espalda, alivia la tensión cervical en 14 días y es 100% invisible bajo tu ropa.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Obtener 33% de Descuento"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "text",
      "id": "delivery_text",
      "label": "Texto debajo del botón",
      "default": "Pago contra entrega disponible"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "URL del video de fondo",
      "accept": ["youtube", "vimeo"],
      "info": "Deja vacío para usar la imagen de fondo"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Imagen de fondo",
      "info": "Se usa cuando no hay video"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
