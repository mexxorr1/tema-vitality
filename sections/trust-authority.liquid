          "default": "shield"
        },
        {
          "type": "text",
          "id": "seal_title",
          "label": "Título do selo",
          "default": "Aprovação Médica"
        },
        {
          "type": "text",
          "id": "seal_description",
          "label": "Descrição",
          "default": "Testado e aprovado por profissionais de saúde."
        }
      ]
    },
    {
      "type": "media_logo",
      "name": "Logo de Mídia",
      "settings": [
        {
