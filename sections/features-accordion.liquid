<section class="w-full mx-auto px-6 md:px-12 xl:px-24 py-20 pb-32">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    
    <div class="order-1 lg:order-1 w-full rounded-[2.5rem] lg:rounded-[3rem] overflow-hidden shadow-2xl h-[500px] lg:h-[700px]">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: 
           class: 'w-full h-full object-cover hover:scale-105 transition-transform duration-[1.5s] ease-out',
           loading: 'lazy'
        }}
      {%- else -%}
        <div class="w-full h-full bg-muted flex items-center justify-center">
          {{ 'image' | placeholder_svg_tag: 'w-32 h-32 text-border' }}
        </div>
      {%- endif -%}
    </div>

    <div class="order-2 lg:order-2">
      {%- if section.settings.heading != blank -%}
        <h2 class="text-4xl md:text-[3.5rem] font-medium tracking-tight leading-[1.1] mb-12 text-foreground">
          {{ section.settings.heading | newline_to_br | replace: 'costas saudáveis', '<span class="text-primary italic">costas saudáveis</span>' }}
        </h2>
      {%- endif -%}
      
      <div class="flex flex-col gap-4">
        {%- for block in section.blocks -%}
          <details name="features" class="group bg-card rounded-2xl border border-border/60 shadow-sm overflow-hidden" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
            <summary class="flex justify-between items-center font-medium cursor-pointer list-none py-5 px-6 hover:text-primary transition-colors text-[1.3rem] text-foreground">
              <span>{{ block.settings.title }}</span>
              <span class="transition-transform duration-300 group-open:rotate-180 text-primary">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
              </span>
            </summary>
            <div class="text-muted-foreground px-6 pb-5 leading-relaxed font-sans text-base">
              {{ block.settings.text }}
            </div>
          </details>
        {%- endfor -%}
      </div>
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Features Accordion",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Alinhe sua coluna e elimine o cansaço para umas \n costas saudáveis"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefício da funcionalidade"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Descrição completa do que esse recurso faz.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Accordion",
      "blocks": [
        {"type": "feature"},
        {"type": "feature"},
        {"type": "feature"}
      ]
    }
  ]
}
{% endschema %}
