<section class="w-full mx-auto py-20 px-6 md:px-12 xl:px-24">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <h2 class="text-4xl md:text-[3.5rem] font-medium tracking-tight text-foreground leading-[1.1]">
        {{ section.settings.heading | default: '¿Por qué Vitality?' }}
      </h2>
    </div>

    <div class="space-y-0 divide-y divide-border/50">
      {%- for block in section.blocks -%}
        <details class="group py-6 md:py-8 cursor-pointer" {{ block.shopify_attributes }}{% if forloop.first %} open{% endif %}>
          <summary class="flex items-center justify-between gap-4 list-none font-medium text-foreground text-lg md:text-xl hover:text-primary transition-colors">
            <div class="flex items-center gap-4">
              <span class="w-10 h-10 rounded-full bg-foreground/5 flex items-center justify-center text-sm font-semibold text-muted-foreground shrink-0">
                {{ forloop.index | prepend: '0' | slice: -2, 2 }}
              </span>
              {{ block.settings.title }}
            </div>
            <svg class="w-5 h-5 shrink-0 text-muted-foreground group-open:rotate-45 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"></path></svg>
          </summary>
          <div class="pl-14 pr-8 pt-4 pb-2 text-muted-foreground leading-relaxed font-sans">
            {{ block.settings.text }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Beneficios Acordeón",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "¿Por qué Vitality?"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Beneficio",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Beneficio de la funcionalidad"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Descripción",
          "default": "<p>Descripción completa de lo que hace este recurso.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beneficios Acordeón",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Corrección postural progresiva",
            "text": "<p>Vitality entrena tu espalda de forma gradual, fortaleciendo los músculos responsables de mantener la columna alineada. A diferencia de corsés rígidos, promueve memoria muscular para resultados duraderos.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Alivio del dolor cervical en 14 días",
            "text": "<p>La tensión cervical y lumbar disminuye progresivamente desde los primeros días. Estudios muestran que el uso diario de 2h redistribuye la presión intervertebral y alivia contracturas crónicas.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "100% invisible bajo la ropa",
            "text": "<p>El diseño ultra delgado (0.3cm) y el tejido transpirable hacen que Vitality sea indetectable bajo camisas, camisetas o blusas. Úsalo en la oficina, gym o vida diaria sin que nadie lo note.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Talla universal + garantía de 30 días",
            "text": "<p>Sistema de ajuste con velcro que se adapta desde la talla XS hasta XXL. Si en 30 días no notas mejora, te devolvemos el 100% de tu dinero. Sin preguntas.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
