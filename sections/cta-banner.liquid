<section class="max-w-6xl mx-auto px-6 md:px-12 mb-20 relative z-20">
  <div class="bg-primary/5 rounded-[3rem] px-8 py-20 text-center relative overflow-hidden border border-primary/10 shadow-xl shadow-primary/5">
    <div class="absolute top-0 right-0 w-[40rem] h-[40rem] bg-primary/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[30rem] h-[30rem] bg-secondary/10 rounded-full blur-3xl translate-y-1/3 -translate-x-1/3 pointer-events-none"></div>
    
    <div class="relative z-10 max-w-2xl mx-auto flex flex-col items-center">
      {%- if section.settings.heading != blank -%}
        <h2 class="text-4xl md:text-6xl tracking-tight leading-[1.05] mb-6 font-medium text-foreground">
          {{ section.settings.heading | replace: 'Experimente', '<span class="text-primary italic">Experimente</span>' }}
        </h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="text-muted-foreground text-lg md:text-xl font-sans mb-10 max-w-lg leading-relaxed">
          {{ section.settings.text }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
        <a href="{{ section.settings.button_link }}" class="bg-primary text-primary-foreground px-12 py-5 rounded-full font-bold shadow-xl hover:shadow-primary/30 hover:brightness-110 active:scale-95 transition-all text-lg tracking-wide mb-6 pulse-button w-full sm:w-auto inline-block text-center cursor-pointer">
          {{ section.settings.button_text }}
        </a>
      {%- endif -%}

      <div class="flex items-center gap-2 text-sm text-foreground/60 font-sans font-medium bg-background/50 backdrop-blur-sm px-4 py-2 rounded-full border border-border/50">
        <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        {{ section.settings.guarantee_text | default: 'Garantia incondicional de 30 dias.' }}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Experimente hoje, sinta-se melhor amanhã."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Content Text",
      "default": "<p>Junte-se a milhares de pessoas que já transformaram suas vidas com uma postura corrigida e livre de dores.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Melhorar minha postura agora"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee Text",
      "default": "Garantia incondicional de 30 dias."
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
