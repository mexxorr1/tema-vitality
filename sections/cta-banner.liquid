<section class="w-full mx-auto px-6 md:px-12 xl:px-24 mb-20 relative">
  <div class="relative rounded-[3rem] overflow-hidden bg-foreground text-background flex flex-col lg:flex-row items-center justify-between min-h-[450px] md:min-h-[500px]">
    
    <!-- Conteúdo Texto -->
    <div class="relative z-10 w-full lg:w-1/2 p-12 lg:p-20 xl:p-24 flex flex-col justify-center h-full">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-background/20 text-background/80 text-sm font-semibold uppercase tracking-widest mb-8 w-fit">
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        {{ section.settings.badge_text | default: 'Seu bem-estar é prioridade' }}
      </div>
      <h2 class="text-4xl sm:text-5xl md:text-[3.5rem] font-medium tracking-tight mb-6 leading-[1.1]">
        Comece a viver <br/><span class="text-primary italic">sem dor hoje.</span>
      </h2>
      <p class="text-lg md:text-xl opacity-80 mb-10 font-sans tracking-wide max-w-lg">
        {{ section.settings.description | default: 'Junte-se a mais de 10.000 clientes que transformaram a sua postura e recuperaram a energia.' }}
      </p>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a href="{{ routes.root_url }}collections/all" class="bg-primary text-primary-foreground px-8 py-4 rounded-full font-semibold hover:brightness-110 active:scale-95 transition-all shadow-[0_0_40px_rgba(0,0,0,0.3)]">
          {{ section.settings.button_text | default: 'Recupere sua Vitalidade' }}
        </a>
        <p class="text-sm opacity-60 mt-2 sm:mt-0 lg:ml-2 font-sans font-medium max-w-[150px] leading-tight">{{ section.settings.guarantee_text | default: '100% de Satisfação ou seu dinheiro de volta.' }}</p>
      </div>
    </div>
    
    <!-- Visual Direito com Cards -->
    <div class="relative w-full lg:w-1/2 min-h-[500px] lg:h-auto lg:absolute lg:top-0 lg:bottom-0 lg:right-0 bg-primary/10 overflow-hidden flex items-center justify-center py-16">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[500px] md:h-[500px] bg-primary/20 rounded-full blur-[80px]"></div>
      <div class="relative w-[340px] md:w-[450px] h-[450px] md:h-[500px] flex items-center justify-center">
        
        <!-- Card 1 -->
        <div class="absolute z-10 top-0 lg:top-4 left-0 w-[200px] md:w-[240px] aspect-square rounded-[2rem] border border-white/10 backdrop-blur-md bg-white/5 p-6 md:p-8 flex flex-col items-center justify-center transform -rotate-6 hover:z-50 hover:-translate-y-4 transition-all duration-500 shadow-xl group cursor-default">
          <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center mb-4 border border-primary/30">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2 text-center text-background tracking-tight leading-tight">Postura Perfeita</h3>
          <p class="text-center text-background/70 font-sans text-sm">Design ultraleve que se adapta ao seu corpo.</p>
        </div>

        <!-- Card 2 com Badge de Rating -->
        <div class="absolute z-20 top-[115px] md:top-[120px] right-0 w-[220px] md:w-[260px] aspect-square rounded-[2.5rem] border border-white/20 backdrop-blur-xl bg-white/10 p-6 md:p-8 flex flex-col items-center justify-center transform rotate-3 hover:z-50 hover:-translate-y-4 transition-all duration-500 shadow-2xl cursor-default">
          <div class="absolute -top-4 -right-4 md:-top-6 md:-right-6 bg-background text-foreground w-16 h-16 md:w-20 md:h-20 rounded-full flex flex-col items-center justify-center shadow-lg z-30 border-4 border-foreground transform rotate-12">
            <span class="text-lg md:text-xl font-bold leading-none tracking-tighter">4.9</span>
            <div class="flex gap-[1px] mt-1 text-primary">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
          </div>
          <div class="w-14 h-14 rounded-full bg-primary/30 flex items-center justify-center mb-4 border border-primary/40">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3 class="text-xl md:text-2xl font-semibold mb-2 text-center text-background tracking-tight leading-tight">Alívio Integral</h3>
          <p class="text-center text-background/70 font-sans text-xs md:text-sm px-2">Elimina drasticamente o estresse nos ombros e pescoço.</p>
        </div>

        <!-- Card 3 -->
        <div class="absolute z-30 bottom-0 lg:bottom-4 left-6 lg:left-12 w-[200px] md:w-[240px] aspect-square rounded-[2rem] border border-white/10 backdrop-blur-md bg-white/5 p-6 md:p-8 flex flex-col items-center justify-center transform -rotate-3 hover:z-50 hover:-translate-y-4 transition-all duration-500 shadow-xl cursor-default">
          <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center mb-4 border border-primary/30">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2 text-center text-background tracking-tight leading-tight">Mais Energia</h3>
          <p class="text-center text-background/70 font-sans text-sm">Ao respirar fundo com o peito aberto, a sua vitalidade dispara.</p>
        </div>

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Seu bem-estar é prioridade"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Junte-se a mais de 10.000 clientes que transformaram a sua postura e recuperaram a energia."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Recupere sua Vitalidade"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee Text",
      "default": "100% de Satisfação ou seu dinheiro de volta."
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
