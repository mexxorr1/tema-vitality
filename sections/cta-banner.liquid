<section class="w-full bg-foreground text-background py-24 px-6 md:px-12 xl:px-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-foreground via-foreground to-foreground/95"></div>
  
  <div class="relative z-10 max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left Content -->
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-background/10 text-sm font-sans mb-6 bg-background/5 backdrop-blur-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-yellow-400"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <span>{{ section.settings.rating_text | default: '4.9 — desde +15,400 reseñas' }}</span>
        </div>

        <h2 class="text-4xl md:text-5xl font-medium tracking-tight leading-[1.1] text-background mb-6">
          {{ section.settings.heading | default: 'Transforma tu postura hoy' }}
        </h2>
        <p class="text-lg text-background/70 font-sans leading-relaxed mb-10 max-w-lg">
          {{ section.settings.description | default: 'Únete a miles de personas que ya recuperaron su bienestar con Vitality. Resultados visibles o te devolvemos tu dinero.' }}
        </p>

        <a href="{{ section.settings.button_link | default: routes.root_url }}" class="inline-flex items-center gap-2 px-8 py-4 bg-background text-foreground font-semibold text-lg rounded-full hover:bg-primary hover:text-primary-foreground hover:scale-105 active:scale-95 transition-all shadow-2xl">
          {{ section.settings.button_text | default: 'Comprar ahora con descuento' }}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Right: Floating Cards -->
      <div class="relative flex justify-center">
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-background/10 backdrop-blur-xl border border-background/10 rounded-3xl p-6 text-center transform hover:-translate-y-2 transition-transform duration-500">
            <span class="text-3xl font-bold text-background block mb-1">14</span>
            <span class="text-sm text-background/60 font-sans">{{ section.settings.card_1_label | default: 'Días para resultados' }}</span>
          </div>
          <div class="bg-background/10 backdrop-blur-xl border border-background/10 rounded-3xl p-6 text-center transform translate-y-4 hover:-translate-y-0 transition-transform duration-500">
            <span class="text-3xl font-bold text-background block mb-1">97%</span>
            <span class="text-sm text-background/60 font-sans">{{ section.settings.card_2_label | default: 'Tasa de satisfacción' }}</span>
          </div>
          <div class="bg-background/10 backdrop-blur-xl border border-background/10 rounded-3xl p-6 text-center transform hover:-translate-y-2 transition-transform duration-500">
            <span class="text-3xl font-bold text-background block mb-1">0.3</span>
            <span class="text-sm text-background/60 font-sans">{{ section.settings.card_3_label | default: 'cm de grosor' }}</span>
          </div>
          <div class="bg-background/10 backdrop-blur-xl border border-background/10 rounded-3xl p-6 text-center transform translate-y-4 hover:-translate-y-0 transition-transform duration-500">
            <span class="text-3xl font-bold text-background block mb-1">30</span>
            <span class="text-sm text-background/60 font-sans">{{ section.settings.card_4_label | default: 'Días de garantía' }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Transforma tu postura hoy"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "Únete a miles de personas que ya recuperaron su bienestar con Vitality. Resultados visibles o te devolvemos tu dinero."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Comprar ahora con descuento"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Texto de puntuación",
      "default": "4.9 — desde +15,400 reseñas"
    },
    {
      "type": "text",
      "id": "card_1_label",
      "label": "Card 1 — Etiqueta",
      "default": "Días para resultados"
    },
    {
      "type": "text",
      "id": "card_2_label",
      "label": "Card 2 — Etiqueta",
      "default": "Tasa de satisfacción"
    },
    {
      "type": "text",
      "id": "card_3_label",
      "label": "Card 3 — Etiqueta",
      "default": "cm de grosor"
    },
    {
      "type": "text",
      "id": "card_4_label",
      "label": "Card 4 — Etiqueta",
      "default": "Días de garantía"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
