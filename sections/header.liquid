<header class="fixed top-0 w-full z-50 bg-background/80 backdrop-blur-xl border-b border-border/50">
  <div class="w-full mx-auto px-6 md:px-12 xl:px-24 h-20 flex items-center justify-between">
    <a href="{{ routes.root_url }}" class="font-serif font-semibold text-3xl tracking-tight text-foreground flex items-center gap-2">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo | image_url: width: 300 | image_tag: 
            class: 'h-10 w-auto mix-blend-multiply hover:opacity-80 transition-opacity',
            alt: shop.name
        }}
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </a>
    
    <nav class="hidden md:flex gap-10 text-sm font-medium text-foreground/80">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="hover:text-primary transition-colors hover:scale-105 transform {% if link.active %}text-primary{% endif %}">
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>
    
    <div class="flex items-center gap-3 md:gap-5">
      <div class="relative group hidden sm:block">
        <button class="flex items-center gap-1 text-sm font-medium hover:text-primary transition-colors py-2 px-2">
          {{ request.locale.iso_code | upcase }} 
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-60"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <!-- A localized menu would hook to routes.all_locales, keeping static for now to match UI visually -->
        <div class="absolute right-0 top-[120%] w-32 bg-card border border-border/50 rounded-2xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 overflow-hidden transform origin-top-right group-hover:translate-y-0 translate-y-2 z-50 p-1">
          <button class="w-full text-left px-4 py-2 text-sm text-primary bg-primary/10 rounded-xl transition-colors font-medium mb-1">🇪🇸 Español</button>
          <button class="w-full text-left px-4 py-2 text-sm text-foreground hover:bg-muted rounded-xl transition-colors font-medium mb-1">🇺🇸 English</button>
          <button class="w-full text-left px-4 py-2 text-sm text-foreground hover:bg-muted rounded-xl transition-colors font-medium">🇧🇷 Português</button>
        </div>
      </div>
      <a href="{{ routes.cart_url }}" id="cart-open-btn" aria-label="Abrir carrinho" class="bg-foreground text-background px-6 py-2.5 rounded-full text-sm font-medium hover:bg-primary hover:text-primary-foreground hover:scale-105 transition-all shadow-md flex items-center justify-center gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        {{ 'cart.title' | t | default: "Carrinho" }}
        {%- if cart.item_count > 0 -%}
          <span class="ml-1 bg-background text-foreground text-xs rounded-full px-2 py-0.5">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Geral Menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
