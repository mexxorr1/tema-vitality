<footer class="bg-foreground text-background w-full">
  <div class="max-w-7xl mx-auto px-6 md:px-12 xl:px-24 pt-20 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8 mb-16">
      
      <!-- Brand Column -->
      <div class="md:col-span-5">
        <a href="{{ routes.root_url }}" class="inline-block mb-6">
          <img
            src="{{ 'imgi_4_with_padding_1.png' | file_url }}"
            alt="{{ shop.name }}"
            class="h-10 invert opacity-90 hover:opacity-100 transition-opacity"
          />
        </a>
        <p class="text-background/60 font-sans text-sm leading-relaxed max-w-sm mb-8">
          {{ section.settings.brand_description | default: 'Corrector de postura inteligente diseñado para entrenar tu espalda y aliviar el dolor cervical de forma permanente.' }}
        </p>

        <!-- Newsletter -->
        <div class="max-w-sm">
          <h4 class="text-sm font-semibold text-background/80 mb-3">{{ 'footer.newsletter_title' | t }}</h4>
          {% form 'customer' %}
            <div class="flex gap-2">
              <input 
                type="email" 
                name="contact[email]" 
                placeholder="{{ 'general.newsletter.label' | t }}" 
                class="flex-1 bg-background/10 border border-background/10 rounded-full px-5 py-3 text-sm text-background placeholder-background/40 focus:outline-none focus:ring-2 focus:ring-primary/50 font-sans"
                required
              />
              <button type="submit" class="bg-background text-foreground px-6 py-3 rounded-full text-sm font-semibold hover:bg-primary hover:text-primary-foreground transition-all active:scale-95 shrink-0">
                {{ 'general.newsletter.button' | t }}
              </button>
            </div>
          {% endform %}
        </div>
      </div>

      <!-- Links Columns -->
      <div class="md:col-span-3 md:col-start-7">
        <h4 class="text-sm font-semibold text-background/80 uppercase tracking-wider mb-5">{{ 'footer.support' | t }}</h4>
        <ul class="space-y-3">
          <li><a href="{{ routes.root_url }}pages/ayuda" class="text-sm text-background/50 hover:text-background transition-colors font-sans">{{ 'footer.help_center' | t }}</a></li>
          <li><a href="{{ routes.root_url }}pages/rastrear" class="text-sm text-background/50 hover:text-background transition-colors font-sans">{{ 'footer.track_order' | t }}</a></li>
          <li><a href="{{ routes.root_url }}pages/contacto" class="text-sm text-background/50 hover:text-background transition-colors font-sans">{{ 'footer.contact' | t }}</a></li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-sm font-semibold text-background/80 uppercase tracking-wider mb-5">{{ 'footer.legal' | t }}</h4>
        <ul class="space-y-3">
          <li><a href="{{ policies.privacy_policy.url }}" class="text-sm text-background/50 hover:text-background transition-colors font-sans">{{ 'footer.privacy_policy' | t }}</a></li>
          <li><a href="{{ policies.terms_of_service.url }}" class="text-sm text-background/50 hover:text-background transition-colors font-sans">{{ 'footer.terms_of_service' | t }}</a></li>
          <li><a href="{{ policies.refund_policy.url }}" class="text-sm text-background/50 hover:text-background transition-colors font-sans">{{ 'footer.refund_policy' | t }}</a></li>
        </ul>
      </div>
    </div>

    <!-- Social Icons -->
    <div class="flex items-center gap-5 mb-10">
      <span class="text-sm text-background/40 font-sans">{{ 'footer.follow_us' | t }}</span>
      {%- if settings.social_instagram_link != blank -%}
        <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-background/5 border border-background/10 flex items-center justify-center hover:bg-background/20 hover:scale-110 transition-all" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-background/70"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      {%- endif -%}
      {%- if settings.social_tiktok_link != blank -%}
        <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-background/5 border border-background/10 flex items-center justify-center hover:bg-background/20 hover:scale-110 transition-all" aria-label="TikTok">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-background/70"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 3 15.57 6.33 6.33 0 0 0 9.37 22a6.33 6.33 0 0 0 6.33-6.33V9.17a8.16 8.16 0 0 0 3.89.98V6.69z"/></svg>
        </a>
      {%- endif -%}
      {%- if settings.social_facebook_link != blank -%}
        <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-background/5 border border-background/10 flex items-center justify-center hover:bg-background/20 hover:scale-110 transition-all" aria-label="Facebook">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-background/70"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      {%- endif -%}
      {%- if settings.social_youtube_link != blank -%}
        <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-background/5 border border-background/10 flex items-center justify-center hover:bg-background/20 hover:scale-110 transition-all" aria-label="YouTube">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-background/70"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      {%- endif -%}
    </div>

    <!-- Payment + Copyright -->
    <div class="border-t border-background/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex flex-col md:flex-row items-center gap-4">
        <p class="text-xs text-background/30 font-sans">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'footer.copyright' | t }}</p>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-xs text-background/30 font-sans">{{ 'footer.secure_payments' | t }}</span>
        <img src="{{ 'bandeiras.png' | file_url }}" alt="Payment methods" class="h-6 opacity-50" loading="lazy">
      </div>
    </div>

    <!-- Big Branding Text -->
    <div class="mt-16 text-center overflow-hidden">
      <span class="text-[6rem] md:text-[10rem] font-bold tracking-tighter text-background/[0.03] leading-none select-none block">
        VITALITY
      </span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Descripción de la marca",
      "default": "Corrector de postura inteligente diseñado para entrenar tu espalda y aliviar el dolor cervical de forma permanente."
    }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
