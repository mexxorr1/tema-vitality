<section id="los-mas-vendidos" class="w-full mx-auto px-6 md:px-12 xl:px-24 py-20 lg:py-28">
  {%- if section.settings.heading != blank -%}
    <h2 class="text-3xl md:text-5xl font-medium tracking-tight mb-12 text-foreground">
      {{ section.settings.heading | replace: 'vendidos', '<span class="text-primary italic">vendidos</span>' }}
    </h2>
  {%- endif -%}
  
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {%- assign collection = collections[section.settings.collection] -%}
    {%- assign limit = section.settings.products_to_show -%}

    {%- if collection != blank and collection.products_count > 0 -%}
      {%- for product in collection.products limit: limit -%}
        <a href="{{ product.url }}" class="group block">
          <div class="relative bg-card rounded-[2rem] overflow-hidden aspect-[4/5] mb-5 flex items-center justify-center p-8 border border-border shadow-sm group-hover:shadow-xl group-hover:shadow-primary/10 transition-all duration-500">
            
            {%- if product.compare_at_price > product.price -%}
              <div class="absolute top-5 left-5 bg-primary text-primary-foreground text-xs uppercase tracking-wider font-bold px-3 py-1.5 rounded-full z-10 shadow-sm">
                {{ 'products.product.on_sale' | t }} {{ product.compare_at_price | minus: product.price | money }}
              </div>
            {%- endif -%}

            {%- if product.featured_image != blank -%}
              {{
                product.featured_image | image_url: width: 600 | image_tag: 
                  class: 'w-full h-full object-contain absolute inset-0 p-8 mix-blend-multiply opacity-100 transition-opacity duration-300 group-hover:opacity-0',
                  loading: 'lazy'
              }}
            {%- endif -%}

            {%- if product.images[1] != blank -%}
              {{
                product.images[1] | image_url: width: 600 | image_tag: 
                  class: 'w-full h-full object-cover absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 scale-105 group-hover:scale-100',
                  loading: 'lazy'
              }}
            {%- endif -%}
            
            <div class="absolute bottom-4 left-4 right-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 z-20">
              <button class="w-full bg-primary text-primary-foreground py-3.5 rounded-full font-semibold shadow-lg hover:brightness-110 active:scale-95 transition-all">
                {{ 'products.product.add_to_cart' | t }}
              </button>
            </div>
          </div>
          
          <div class="px-2">
            <h3 class="font-medium text-foreground text-[1.1rem] mb-2 leading-tight">{{ product.title }}</h3>
            <div class="flex items-center justify-between text-muted-foreground text-sm font-sans">
              <div class="flex whitespace-nowrap gap-2 items-center">
                <span class="text-foreground font-semibold text-lg">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="line-through text-xs opacity-60">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
              {%- if product.metafields.custom.short_feature != blank -%}
                <span>{{ product.metafields.custom.short_feature }}</span>
              {%- else -%}
                 <span>{{ product.tags.first }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      <!-- Fallback view when no collection is selected -->
      {%- for i in (1..4) -%}
        <div class="group block">
          <div class="relative bg-card rounded-[2rem] overflow-hidden aspect-[4/5] mb-5 flex items-center justify-center p-8 border border-border shadow-sm">
            {{ 'product-' | append: i | placeholder_svg_tag: 'w-full h-full text-muted' }}
          </div>
          <div class="px-2">
            <h3 class="font-medium text-foreground text-[1.1rem] mb-2 leading-tight">Produto Exemplo {{ i }}</h3>
            <div class="flex items-center justify-between text-muted-foreground text-sm font-sans">
              <span class="text-foreground font-semibold text-lg">$ 39.00 USD</span>
              <span>Destaque</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Os mais vendidos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Best Sellers"
    }
  ]
}
{% endschema %}
