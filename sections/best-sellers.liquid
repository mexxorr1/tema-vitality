<section class="w-full mx-auto py-20 px-6 md:px-12 xl:px-24">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-14 gap-4">
    <h2 class="text-4xl md:text-[3.5rem] font-medium tracking-tight text-foreground leading-[1.1]">
      {{ section.settings.heading | default: 'Los más vendidos' }}
    </h2>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-8">
    {%- if section.settings.collection != blank -%}
      {%- for product in collections[section.settings.collection].products limit: section.settings.products_to_show -%}
        <a href="{{ product.url }}" class="group block">
          <div class="relative bg-card rounded-[2rem] overflow-hidden aspect-[4/5] mb-5 border border-border shadow-sm hover:shadow-xl hover:shadow-primary/10 transition-all duration-500">
            {%- if product.featured_image -%}
              <img 
                src="{{ product.featured_image | image_url: width: 600 }}" 
                alt="{{ product.featured_image.alt | escape }}" 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
                width="600"
                height="750"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'w-full h-full text-muted p-8' }}
            {%- endif -%}

            {%- if product.compare_at_price > product.price -%}
              {%- assign savings = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
              <span class="absolute top-4 left-4 bg-accent text-white text-xs font-semibold px-3 py-1 rounded-full">
                -{{ savings }}%
              </span>
            {%- endif -%}

            <div class="absolute bottom-0 inset-x-0 p-6 pt-10 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <button class="w-full bg-primary text-primary-foreground py-3.5 rounded-full font-semibold shadow-lg hover:brightness-110 active:scale-95 transition-all">
                {{ 'products.product.add_to_cart' | t }}
              </button>
            </div>
          </div>
          
          <div class="px-2">
            <h3 class="font-medium text-foreground text-[1.1rem] mb-2 leading-tight">{{ product.title }}</h3>
            <div class="flex items-center justify-between text-muted-foreground text-sm font-sans">
              <div class="flex whitespace-nowrap gap-2 items-center">
                <span class="text-foreground font-semibold text-lg">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="line-through text-xs opacity-60">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
              {%- if product.metafields.custom.short_feature != blank -%}
                <span>{{ product.metafields.custom.short_feature }}</span>
              {%- else -%}
                 <span>{{ product.tags.first }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="group block">
          <div class="relative bg-card rounded-[2rem] overflow-hidden aspect-[4/5] mb-5 flex items-center justify-center p-8 border border-border shadow-sm">
            {{ 'product-' | append: i | placeholder_svg_tag: 'w-full h-full text-muted' }}
          </div>
          <div class="px-2">
            <h3 class="font-medium text-foreground text-[1.1rem] mb-2 leading-tight">Producto Ejemplo {{ i }}</h3>
            <div class="flex items-center justify-between text-muted-foreground text-sm font-sans">
              <span class="text-foreground font-semibold text-lg">$ 39.00 USD</span>
              <span>Destacado</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Más Vendidos",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Los más vendidos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección a mostrar"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Productos a mostrar",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Más Vendidos"
    }
  ]
}
{% endschema %}
