<section class="w-full mx-auto py-20 px-6 md:px-12 xl:px-24">
  <div class="text-center mb-14">
    <h2 class="text-4xl md:text-[3.5rem] font-medium tracking-tight text-foreground leading-[1.1]">
      {{ section.settings.heading | default: 'Elige tu pack' }}
    </h2>
    {%- if section.settings.subheading != blank -%}
      <p class="text-muted-foreground text-lg font-sans mt-4 max-w-lg mx-auto">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto items-stretch">
    {%- for block in section.blocks -%}
      <div class="relative bg-card rounded-[2rem] border {% if block.settings.featured %}border-primary shadow-2xl shadow-primary/20 scale-[1.02] md:scale-105{% else %}border-border/50 shadow-sm{% endif %} p-8 flex flex-col transition-all hover:shadow-xl hover:-translate-y-1 duration-300" {{ block.shopify_attributes }}>
        
        {%- if block.settings.badge != blank -%}
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-primary-foreground text-xs font-semibold px-4 py-1.5 rounded-full whitespace-nowrap shadow-lg">
            {{ block.settings.badge }}
          </span>
        {%- endif -%}

        <h3 class="text-xl font-semibold text-foreground mb-2">{{ block.settings.title }}</h3>
        <p class="text-sm text-muted-foreground font-sans mb-6">{{ block.settings.description }}</p>

        <div class="mb-6">
          <div class="flex items-baseline gap-2">
            <span class="text-4xl font-bold text-foreground">{{ block.settings.price }}</span>
            {%- if block.settings.compare_price != blank -%}
              <span class="text-lg line-through text-muted-foreground/50">{{ block.settings.compare_price }}</span>
            {%- endif -%}
          </div>
          {%- if block.settings.unit_price != blank -%}
            <p class="text-sm text-muted-foreground font-sans mt-1">{{ block.settings.unit_price }}</p>
          {%- endif -%}
        </div>

        <ul class="space-y-3 mb-8 flex-1">
          {%- assign benefits = block.settings.benefits | split: '|' -%}
          {%- for benefit in benefits -%}
            <li class="flex items-start gap-3 text-sm text-foreground/80 font-sans">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              {{ benefit | strip }}
            </li>
          {%- endfor -%}
        </ul>

        <a href="{{ block.settings.button_link | default: routes.root_url }}" class="w-full text-center py-4 rounded-full font-semibold transition-all active:scale-95 {% if block.settings.featured %}bg-primary text-primary-foreground hover:brightness-110 shadow-lg{% else %}bg-foreground/5 text-foreground hover:bg-foreground/10 border border-border/50{% endif %}">
          {{ block.settings.button_text | default: 'Comprar ahora' }}
        </a>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Precios por Pack",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Elige tu pack"
