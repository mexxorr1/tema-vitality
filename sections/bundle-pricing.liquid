<section class="w-full mx-auto px-6 md:px-12 xl:px-24 py-24 pb-32">
  <div class="text-center mb-16">
    <h2 class="text-4xl md:text-[3.5rem] font-medium tracking-tight text-foreground leading-[1.1] mb-4">
      {{ section.settings.heading | replace: 'Pacote Ideal', '<span class="text-primary italic">Pacote Ideal</span>' }}
    </h2>
    <p class="text-muted-foreground text-lg max-w-2xl mx-auto font-sans">
      {{ section.settings.subheading }}
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center max-w-5xl mx-auto">
    {%- for block in section.blocks -%}
      {%- assign product = block.settings.product -%}
      
      <div class="relative {% if block.settings.is_highlighted %}bg-card border-2 border-primary rounded-[2.5rem] p-8 lg:p-10 shadow-2xl shadow-primary/10 transform md:-translate-y-4 z-10 mb-8 md:mb-0{% else %}bg-card border border-border/80 rounded-[2.5rem] p-8 lg:p-10 shadow-sm hover:shadow-xl transition-all duration-300{% endif %} flex flex-col h-full w-full" {{ block.shopify_attributes }}>
        
        {%- if block.settings.badge_text != blank -%}
          <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-primary text-primary-foreground text-xs font-bold uppercase tracking-widest py-1.5 px-5 rounded-full shadow-md whitespace-nowrap">
            {{ block.settings.badge_text }}
          </div>
        {%- endif -%}
        
        <h3 class="text-2xl font-medium text-foreground tracking-tight mb-2 {% if block.settings.badge_text != blank %}mt-2{% endif %}">{{ block.settings.title }}</h3>
        <p class="text-muted-foreground text-sm font-sans mb-6">{{ block.settings.description }}</p>
        
        <div class="flex flex-col mb-6">
          {%- if product != blank and product.compare_at_price > product.price -%}
            <span class="text-muted-foreground line-through text-lg font-sans">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          
          <span class="{% if block.settings.is_highlighted %}text-5xl text-primary{% else %}text-4xl text-foreground{% endif %} font-semibold">
            {%- if product != blank -%}
              {{ product.price | money }}
            {%- else -%}
              $39.00
            {%- endif -%}
            <span class="text-base text-muted-foreground font-normal">{{ block.settings.price_suffix }}</span>
          </span>
        </div>
        
        <div class="{% if block.settings.is_highlighted %}bg-primary/5 border border-primary/20{% else %}bg-muted/50{% endif %} rounded-2xl p-6 mb-8 flex-grow">
          <ul class="flex flex-col gap-4 font-sans text-sm text-foreground/80">
            {%- if block.settings.feature_1 != blank -%}
              <li class="flex items-center gap-3 {% if block.settings.is_highlighted %}font-medium{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary shrink-0"><path d="M20 6L9 17l-5-5"/></svg>
                {{ block.settings.feature_1 }}
              </li>
            {%- endif -%}
            {%- if block.settings.feature_2 != blank -%}
              <li class="flex items-center gap-3 {% if block.settings.is_highlighted %}font-medium text-primary{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary shrink-0"><path d="M20 6L9 17l-5-5"/></svg>
                {{ block.settings.feature_2 }}
              </li>
            {%- endif -%}
          </ul>
        </div>
        
        <form method="post" action="/cart/add" class="mt-auto flex w-full">
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          <button type="submit" class="w-full {% if block.settings.is_highlighted %}bg-primary text-primary-foreground hover:brightness-110 py-4.5 pulse-button shadow-lg hover:shadow-primary/30{% else %}bg-foreground text-background hover:bg-primary hover:text-primary-foreground py-4 shadow-md hover:shadow-lg{% endif %} rounded-full font-semibold transition-all flex items-center justify-center">
            {{ block.settings.button_text | default: 'Selecionar Plano' }}
          </button>
        </form>

      </div>
    {%- endfor -%}
  </div>
  
  <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 mt-16 opacity-70">
    <div class="flex items-center gap-3 font-sans font-medium text-foreground">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      <span class="text-sm">Pagamento 100% Seguro</span>
    </div>
    <div class="flex items-center gap-3 font-sans font-medium text-foreground">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      <span class="text-sm">Garantia de 30 Dias</span>
    </div>
    <div class="flex items-center gap-3 font-sans font-medium text-foreground">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
      <span class="text-sm">Suporte 24/7</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bundle Pricing",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Escolha seu Pacote Ideal"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Aproveite nossos descontos por volume. As ofertas desta página expiram em breve."
    }
  ],
  "blocks": [
    {
      "type": "pricing_tier",
      "name": "Pricing Tier",
      "limit": 3,
      "settings": [
        {
          "type": "checkbox",
          "id": "is_highlighted",
          "label": "Highlight this tier?",
          "default": false
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text",
          "info": "Ex: Mais Vendido"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Plan Name",
          "default": "Pacote Básico"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Plan Description"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Shopify Product"
        },
        {
          "type": "text",
          "id": "price_suffix",
          "label": "Price Suffix",
          "default": "/unidade"
        },
        {
          "type": "text",
          "id": "feature_1",
          "label": "Feature 1"
        },
        {
          "type": "text",
          "id": "feature_2",
          "label": "Feature 2"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Selecionar Plano"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundle Pricing",
      "blocks": [
        {"type": "pricing_tier"},
        {"type": "pricing_tier", "settings": {"is_highlighted": true}},
        {"type": "pricing_tier"}
      ]
    }
  ]
}
{% endschema %}
