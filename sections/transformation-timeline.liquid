{% comment %}
  ╔══════════════════════════════════════════════════════════════════════════════╗
  ║  TRANSFORMATION TIMELINE — Seção Premium de Resultado Visual               ║
  ║  Exibe a jornada de transformação em 14 dias com marcos de progresso.       ║
  ║  100% nativo: CSS custom properties + scroll-driven animation.             ║
  ╚══════════════════════════════════════════════════════════════════════════════╝
{% endcomment %}

<section
  id="transformation-timeline"
  class="transformation-timeline"
  aria-label="{{ section.settings.heading | default: 'Sua Transformação em 14 Dias' }}"
>
  <div class="container">
    {%- comment -%} Header da seção {%- endcomment -%}
    <div class="tl-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="tl-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="tl-title">
        {{ section.settings.heading | default: 'Sua Transformação em <em>14 Dias</em>' }}
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p class="tl-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Antes / Depois Visual {%- endcomment -%}
    <div class="tl-comparison">
      <div class="tl-comparison__card tl-comparison__card--before">
        <div class="tl-comparison__badge tl-comparison__badge--before">Antes</div>
        <div class="tl-comparison__img-wrap">
          {%- if section.settings.image_before != blank -%}
            {{ section.settings.image_before | image_url: width: 600 | image_tag:
              class: 'tl-comparison__img',
              loading: 'lazy',
              alt: 'Postura antes do corretor'
            }}
          {%- else -%}
            <div class="tl-comparison__placeholder">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2a4 4 0 1 0 0 8 4 4 0 0 0 0-8z"/>
                <path d="M12 10c-4 0-7 2-7 5v4h14v-4c0-3-3-5-7-5z"/>
                <path d="M8 14l4 6 4-6" stroke-dasharray="3 3"/>
              </svg>
              <span>Postura curvada</span>
            </div>
          {%- endif -%}
        </div>
        <ul class="tl-comparison__symptoms">
          {%- assign symptoms = section.settings.symptoms_before | split: '|' -%}
          {%- for symptom in symptoms -%}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-error)" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              {{ symptom | strip }}
            </li>
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} Seta central animada {%- endcomment -%}
      <div class="tl-comparison__arrow" aria-hidden="true">
        <div class="tl-comparison__arrow-line"></div>
        <svg width="32" height="32" viewBox="0 0 24 24" fill="var(--color-primary)"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
      </div>

      <div class="tl-comparison__card tl-comparison__card--after">
        <div class="tl-comparison__badge tl-comparison__badge--after">Depois</div>
        <div class="tl-comparison__img-wrap">
          {%- if section.settings.image_after != blank -%}
            {{ section.settings.image_after | image_url: width: 600 | image_tag:
              class: 'tl-comparison__img',
              loading: 'lazy',
              alt: 'Postura corrigida após 14 dias'
            }}
          {%- else -%}
            <div class="tl-comparison__placeholder tl-comparison__placeholder--success">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2a4 4 0 1 0 0 8 4 4 0 0 0 0-8z"/>
                <path d="M12 10c-4 0-7 2-7 5v4h14v-4c0-3-3-5-7-5z"/>
                <line x1="12" y1="10" x2="12" y2="19"/>
              </svg>
              <span>Postura alinhada</span>
            </div>
          {%- endif -%}
        </div>
        <ul class="tl-comparison__benefits">
          {%- assign benefits = section.settings.benefits_after | split: '|' -%}
          {%- for benefit in benefits -%}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              {{ benefit | strip }}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>

    {%- comment -%} Linha do tempo de progresso {%- endcomment -%}
    <div class="tl-progress" role="list" aria-label="Marcos de progresso">
      {%- for block in section.blocks -%}
        <div class="tl-progress__item" role="listitem" {{ block.shopify_attributes }}
             style="--item-delay: {{ forloop.index0 | times: 150 }}ms;">
          <div class="tl-progress__marker">
            <span class="tl-progress__day">{{ block.settings.day_label }}</span>
            <div class="tl-progress__dot">
              {%- if block.settings.icon == 'check' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              {%- elsif block.settings.icon == 'star' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
              {%- else -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              {%- endif -%}
            </div>
          </div>
          <div class="tl-progress__content">
            <h3 class="tl-progress__title">{{ block.settings.title }}</h3>
            <p class="tl-progress__text">{{ block.settings.description }}</p>
          </div>
          {%- unless forloop.last -%}
            <div class="tl-progress__connector" aria-hidden="true"></div>
          {%- endunless -%}
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} CTA final {%- endcomment -%}
    {%- if section.settings.cta_text != blank -%}
      <div class="tl-cta">
        <a href="{{ section.settings.cta_url | default: '#los-mas-vendidos' }}" class="btn btn--primary btn--lg tl-cta__btn">
          {{ section.settings.cta_text }}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
        </a>
        {%- if section.settings.cta_subtext != blank -%}
          <p class="tl-cta__sub">{{ section.settings.cta_subtext }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  /* ─── Transformation Timeline ─────────────────────────────────────────── */
  .transformation-timeline {
    padding: var(--space-20) 0;
    background: var(--color-bg);
    overflow: hidden;
  }

  /* Header */
  .tl-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .tl-eyebrow {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-4);
  }

  .tl-title {
    font-size: clamp(1.75rem, 4vw, var(--font-size-5xl));
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .tl-title em {
    font-style: italic;
    color: var(--color-primary);
  }

  .tl-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    max-width: 540px;
    margin-inline: auto;
    line-height: var(--line-height-relaxed);
  }

  /* ─── Comparison Cards ─────────────────────────────────────────────────── */
  .tl-comparison {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-6);
    align-items: center;
    margin-bottom: var(--space-16);
    max-width: 900px;
    margin-inline: auto;
  }

  .tl-comparison__card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .tl-comparison__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .tl-comparison__badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    z-index: 2;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .tl-comparison__badge--before {
    background: var(--color-error);
    color: #fff;
  }

  .tl-comparison__badge--after {
    background: var(--color-success);
    color: #fff;
  }

  .tl-comparison__img-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-bg-secondary);
  }

  .tl-comparison__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .tl-comparison__card:hover .tl-comparison__img {
    transform: scale(1.05);
  }

  .tl-comparison__placeholder,
  .tl-comparison__placeholder--success {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  .tl-comparison__placeholder--success {
    color: var(--color-success);
  }

  .tl-comparison__symptoms,
  .tl-comparison__benefits {
    padding: var(--space-4) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .tl-comparison__symptoms li,
  .tl-comparison__benefits li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text);
    font-weight: var(--font-weight-medium);
  }

  .tl-comparison__symptoms li svg,
  .tl-comparison__benefits li svg {
    flex-shrink: 0;
  }

  /* ─── Arrow {%- endcomment -%} */
  .tl-comparison__arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .tl-comparison__arrow-line {
    width: 2px;
    height: 40px;
    background: linear-gradient(to bottom, transparent, var(--color-primary));
  }

  .tl-comparison__arrow svg {
    animation: tl-pulse-arrow 2s ease-in-out infinite;
  }

  @keyframes tl-pulse-arrow {
    0%, 100% { transform: translateX(0); opacity: 0.7; }
    50%      { transform: translateX(4px); opacity: 1; }
  }

  /* ─── Progress Timeline ────────────────────────────────────────────────── */
  .tl-progress {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
    max-width: 1100px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .tl-progress__item {
    text-align: center;
    position: relative;
    opacity: 0;
    transform: translateY(24px);
    animation: tl-fade-in 0.5s ease forwards;
    animation-delay: var(--item-delay, 0ms);
  }

  @keyframes tl-fade-in {
    to { opacity: 1; transform: translateY(0); }
  }

  .tl-progress__marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .tl-progress__day {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
  }

  .tl-progress__dot {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-primary) 20%, transparent);
    transition: transform var(--transition-fast);
  }

  .tl-progress__item:hover .tl-progress__dot {
    transform: scale(1.15);
  }

  .tl-progress__title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .tl-progress__text {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: var(--line-height-relaxed);
  }

  .tl-progress__connector {
    display: none;
  }

  /* ─── CTA ──────────────────────────────────────────────────────────────── */
  .tl-cta {
    text-align: center;
  }

  .tl-cta__btn {
    padding: var(--space-4) var(--space-10);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-xl);
    transition: all var(--transition-fast);
  }

  .tl-cta__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px color-mix(in srgb, var(--color-primary) 30%, transparent);
  }

  .tl-cta__sub {
    margin-top: var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  /* ─── Mobile ───────────────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .transformation-timeline {
      padding: var(--space-12) 0;
    }

    .tl-comparison {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .tl-comparison__arrow {
      flex-direction: row;
      justify-content: center;
    }

    .tl-comparison__arrow-line {
      width: 40px;
      height: 2px;
      background: linear-gradient(to right, transparent, var(--color-primary));
    }

    .tl-comparison__arrow svg {
      animation: tl-pulse-arrow-mobile 2s ease-in-out infinite;
    }

    @keyframes tl-pulse-arrow-mobile {
      0%, 100% { transform: translateY(0); opacity: 0.7; }
      50%      { transform: translateY(4px); opacity: 1; }
    }

    .tl-progress {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .tl-progress__item {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: var(--space-4);
      text-align: left;
    }

    .tl-progress__content {
      padding-top: var(--space-1);
    }
  }
</style>

{% schema %}
{
  "name": "Transformação 14 Dias",
  "tag": "section",
  "class": "section-transformation",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (subtítulo acima)",
      "default": "Resultados Comprovados"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Título",
      "default": "Sua Transformação em <em>14 Dias</em>"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Treino progressivo que corrige sua postura naturalmente — sem desconforto."
    },
    {
      "type": "image_picker",
      "id": "image_before",
      "label": "Imagem — Antes"
    },
    {
      "type": "image_picker",
      "id": "image_after",
      "label": "Imagem — Depois"
    },
    {
      "type": "text",
      "id": "symptoms_before",
      "label": "Sintomas 'Antes' (separe com |)",
      "default": "Dor nas costas crônica|Tensão no pescoço|Fadiga constante|Postura curvada"
    },
    {
      "type": "text",
      "id": "benefits_after",
      "label": "Benefícios 'Depois' (separe com |)",
      "default": "Coluna alinhada|Zero dor cervical|Mais energia|Postura confiante"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto do Botão CTA",
      "default": "Começar Minha Transformação"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link do CTA"
    },
    {
      "type": "text",
      "id": "cta_subtext",
      "label": "Texto abaixo do CTA",
      "default": "✦ Garantia de 30 dias — Risco zero"
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Marco de Progresso",
      "settings": [
        {
          "type": "text",
          "id": "day_label",
          "label": "Rótulo do dia",
          "default": "Dia 1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Alívio Inicial"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descrição",
          "default": "Sinta a diferença logo na primeira utilização."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Ícone",
          "options": [
            { "value": "bolt", "label": "Raio" },
            { "value": "check", "label": "Check" },
            { "value": "star", "label": "Estrela" }
          ],
          "default": "bolt"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Transformação 14 Dias",
      "blocks": [
        {
          "type": "milestone",
          "settings": {
            "day_label": "Dia 1",
            "title": "Alívio Instantâneo",
            "description": "Tensão cervical reduzida imediatamente ao vestir o corretor.",
            "icon": "bolt"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "day_label": "Dia 5",
            "title": "Memória Muscular",
            "description": "Seus músculos começam a memorizar a posição correta.",
            "icon": "check"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "day_label": "Dia 10",
            "title": "Postura Automática",
            "description": "Você já mantém a coluna reta sem pensar.",
            "icon": "check"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "day_label": "Dia 14",
            "title": "Transformação Completa",
            "description": "Postura naturalmente corrigida. Dor eliminada.",
            "icon": "star"
          }
        }
      ]
    }
  ]
}
{% endschema %}
