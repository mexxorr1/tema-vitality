<section class="w-full mx-auto py-20 px-6 md:px-12 xl:px-24">
  <div class="max-w-3xl mx-auto">
    {%- if product.featured_image -%}
      <div class="mb-10">
        <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.featured_image.alt | escape }}" class="w-full rounded-3xl" loading="eager">
      </div>
    {%- endif -%}

    <h1 class="text-4xl md:text-5xl font-medium tracking-tight text-foreground leading-[1.1] mb-4">
      {{ product.title }}
    </h1>

    <div class="flex items-baseline gap-3 mb-8">
      <span class="text-3xl font-bold text-foreground">{{ product.price | money }}</span>
      {%- if product.compare_at_price > product.price -%}
        <span class="text-lg line-through text-muted-foreground/50">{{ product.compare_at_price | money }}</span>
        {%- assign savings = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
        <span class="bg-accent/10 text-accent text-sm font-semibold px-3 py-1 rounded-full">-{{ savings }}%</span>
      {%- endif -%}
    </div>

    {%- if product.description != blank -%}
      <div class="prose prose-lg text-muted-foreground font-sans mb-10 leading-relaxed">
        {{ product.description }}
      </div>
    {%- endif -%}

    {% form 'product', product %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div class="mb-6">
            <label class="block text-sm font-semibold text-foreground mb-3">{{ option.name }}</label>
            <div class="flex flex-wrap gap-2">
              {%- for value in option.values -%}
                <label class="cursor-pointer">
                  <input type="radio" name="{{ option.name }}" value="{{ value }}" {% if option.selected_value == value %}checked{% endif %} class="peer hidden">
                  <span class="inline-block px-5 py-2.5 rounded-full border border-border text-sm font-medium peer-checked:bg-foreground peer-checked:text-background peer-checked:border-foreground transition-all hover:border-foreground/50">
                    {{ value }}
                  </span>
                </label>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      <button type="submit" class="w-full bg-primary text-primary-foreground py-4 rounded-full font-semibold text-lg hover:brightness-110 active:scale-[0.98] transition-all shadow-lg {% unless product.available %}opacity-50 cursor-not-allowed{% endunless %}" {% unless product.available %}disabled{% endunless %}>
        {%- if product.available -%}
          {{ 'products.product.add_to_cart' | t }}
        {%- else -%}
          {{ 'products.product.sold_out' | t }}
        {%- endif -%}
      </button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Producto Principal",
  "settings": [],
  "presets": [{ "name": "Producto Principal" }]
}
{% endschema %}
