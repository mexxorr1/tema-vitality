<!-- Cart Drawer Overlay -->
<div id="cart-overlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[998] opacity-0 pointer-events-none transition-opacity duration-300" data-cart-close></div>

<!-- Cart Drawer Panel -->
<aside id="cart-drawer" class="fixed top-0 right-0 h-full w-full max-w-md bg-background z-[999] shadow-2xl transform translate-x-full transition-transform duration-300 ease-out flex flex-col">
  
  <!-- Header -->
  <div class="flex items-center justify-between px-6 py-5 border-b border-border/50">
    <h2 class="text-xl font-semibold tracking-tight text-foreground">{{ 'cart.title' | t }}</h2>
    <button data-cart-close class="w-10 h-10 rounded-full bg-muted/50 flex items-center justify-center hover:bg-muted transition-colors" aria-label="{{ 'accessibility.close' | t }}">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <!-- Cart Items -->
  <div class="flex-1 overflow-y-auto px-6 py-4">
    {%- if cart.item_count > 0 -%}
      {%- for item in cart.items -%}
        <div class="flex gap-4 py-4 border-b border-border/30 last:border-0">
          <a href="{{ item.url }}" class="shrink-0">
            {%- if item.image -%}
              <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title | escape }}" class="w-20 h-20 object-cover rounded-xl border border-border/50" loading="lazy">
            {%- else -%}
              <div class="w-20 h-20 bg-muted rounded-xl flex items-center justify-center">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted-foreground"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
            {%- endif -%}
          </a>
          <div class="flex-1 min-w-0">
            <a href="{{ item.url }}" class="text-sm font-medium text-foreground hover:text-primary transition-colors line-clamp-2">{{ item.product.title }}</a>
            {%- unless item.product.has_only_default_variant -%}
              <p class="text-xs text-muted-foreground mt-0.5">{{ item.variant.title }}</p>
            {%- endunless -%}
            <div class="flex items-center justify-between mt-2">
              <div class="flex items-center gap-2 bg-muted/50 rounded-full">
                <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | minus: 1 }}" class="w-8 h-8 flex items-center justify-center text-foreground hover:text-primary transition-colors rounded-full">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/></svg>
                </a>
                <span class="text-sm font-medium w-6 text-center">{{ item.quantity }}</span>
                <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | plus: 1 }}" class="w-8 h-8 flex items-center justify-center text-foreground hover:text-primary transition-colors rounded-full">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                </a>
              </div>
              <span class="text-sm font-semibold text-foreground">{{ item.final_line_price | money }}</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="flex flex-col items-center justify-center h-full text-center py-20">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-muted-foreground/40 mb-6">
          <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <p class="text-muted-foreground font-sans text-lg mb-2">{{ 'cart.empty' | t }}</p>
        <a href="{{ routes.root_url }}" data-cart-close class="text-primary font-semibold text-sm hover:underline mt-2">{{ 'cart.continue_shopping' | t }}</a>
      </div>
    {%- endif -%}
  </div>

  <!-- Footer -->
  {%- if cart.item_count > 0 -%}
    <div class="border-t border-border/50 px-6 py-5 bg-background">
      <div class="flex justify-between items-center mb-4">
        <span class="text-sm text-muted-foreground font-sans">{{ 'cart.subtotal' | t }}</span>
        <span class="text-xl font-semibold text-foreground">{{ cart.total_price | money }}</span>
      </div>
      <p class="text-xs text-muted-foreground font-sans mb-4">{{ 'cart.shipping_note' | t }}</p>
      <a href="{{ routes.cart_url }}/checkout" class="w-full bg-primary text-primary-foreground py-4 rounded-full font-semibold text-center block hover:brightness-110 active:scale-[0.98] transition-all shadow-lg">
        {{ 'cart.checkout' | t }}
      </a>
    </div>
  {%- endif -%}
</aside>
