{%- if product != blank -%}
<div id="sticky-cart-bar" class="fixed bottom-0 left-0 w-full bg-background border-t border-border shadow-[0_-10px_40px_rgba(0,0,0,0.05)] z-[100] transform translate-y-full transition-transform duration-500 flex items-center justify-between p-4 md:px-8">
  <div class="hidden md:flex items-center gap-4">
    {%- if product.featured_image != blank -%}
      {{ product.featured_image | image_url: width: 80 | image_tag: class: 'w-12 h-12 rounded-lg object-cover', alt: product.featured_image.alt | escape }}
    {%- endif -%}
    <div>
      <p class="text-sm font-semibold text-foreground">{{ product.title }}</p>
      <p class="text-xs text-muted-foreground flex items-center gap-2">
        <span class="text-primary font-bold">{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}
          <span class="line-through opacity-70">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </p>
    </div>
  </div>
  
  <div class="flex items-center justify-between md:justify-end gap-4 w-full md:w-auto">
    <div class="md:hidden flex flex-col">
      <span class="text-xs text-muted-foreground">Preço Total</span>
      <span class="text-lg text-primary font-bold leading-none">{{ product.price | money }}</span>
    </div>
    
    <form method="post" action="/cart/add">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <button type="submit" class="bg-primary text-primary-foreground font-bold px-8 py-3.5 flex items-center gap-2 rounded-full shadow-lg hover:shadow-primary/30 pulse-button whitespace-nowrap active:scale-95 transition-all text-sm md:text-base">
        Comprar Agora
        <svg fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
      </button>
    </form>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Only engage sticky bar if we are on a page that acts like a product page layout
    // We attach an observer to the Hero CTA or main Add To Cart button
    const heroButton = document.querySelector('.pulse-button');
    const stickyBar = document.getElementById('sticky-cart-bar');
    
    if (heroButton && stickyBar) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) {
            stickyBar.classList.remove('translate-y-full'); // Show
          } else {
            stickyBar.classList.add('translate-y-full'); // Hide
          }
        });
      }, {
        root: null,
        threshold: 0,
        rootMargin: "-100px 0px 0px 0px"
      });
      
      observer.observe(heroButton);
    }
  });
</script>
{%- endif -%}
