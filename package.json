{
  "name": "antigravity-shopify-theme",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "dev": "shopify theme dev",
    "dev:css": "npx @tailwindcss/cli -i ./assets/input.css -o ./assets/theme.css --watch",
    "build:css": "npx @tailwindcss/cli -i ./assets/input.css -o ./assets/theme.css --minify",
    "push": "npm run build:css && shopify theme push --unpublished",
    "check": "shopify theme check"
  },
  "devDependencies": {
    "tailwindcss": "^4.0.0",
    "@tailwindcss/cli": "^4.0.0"
  }
}
